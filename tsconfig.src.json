{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "checkJs": true,
    "jsx": "preserve",
    "tsBuildInfoFile": "${configDir}/dist-types/tsconfig.src.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "scripts/**/*.ts",
    "types/**/*.d.ts",
    "vite.config.ts",
    ".lintstagedrc.ts",
    "eslint.config.js",
    "lighthouserc.cjs"
  ]
}
